# Bluefin App Environment Configuration
# Copy this file to .env and fill with real values.

# Core API
EXPO_PUBLIC_API_URL=https://example.com/v4

# OneSignal
EXPO_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id

# Google Maps API Keys
GOOGLE_MAPS_ANDROID_API_KEY=your_google_maps_android_api_key
GOOGLE_MAPS_IOS_API_KEY=your_google_maps_ios_api_key

# AppsFlyer
EXPO_PUBLIC_APPSFLYER_DEV_KEY=your_appsflyer_dev_key
EXPO_PUBLIC_APPSFLYER_IOS_APP_ID=your_ios_app_id
EXPO_PUBLIC_APPSFLYER_ANDROID_APP_ID=your_android_app_id

# OSMI
EXPO_PUBLIC_OSMI_API_URL=https://example-osmi.com/api/v3
EXPO_PUBLIC_OSMI_API_KEY=your_osmi_api_key
EXPO_PUBLIC_OSMI_OAUTH_KEY=your_osmi_oauth_key

# Aiko
EXPO_PUBLIC_AIKO_API_KEY=your_aiko_api_key

# AppMetrica (optional)
EXPO_PUBLIC_APPMETRICA_TOKEN=your_appmetrica_token
